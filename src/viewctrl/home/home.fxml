<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: #fcc36d;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.home.HomeController">
   <children>
      <VBox alignment="CENTER" prefHeight="299.0" prefWidth="515.0" spacing="10.0">
         <children>
            <TextField fx:id="benutzernameTF" maxWidth="300.0" promptText="Benutzername" style="-fx-background-color: #fff8e0; -fx-background-radius: 100px;" />
            <TextField fx:id="passwortTF" maxWidth="300.0" promptText="Passwort" style="-fx-background-color: #fff8e0; -fx-background-radius: 100px;" />
            <HBox alignment="CENTER" prefHeight="22.0" prefWidth="500.0" spacing="25.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#anmelden" style="-fx-background-color: #fcc36d;" text="Anmelden">
                     <font>
                        <Font name="Century Gothic" size="16.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#benutzerErstellen" style="-fx-background-color: #fcc36d;" text="Benutzer erstellen">
                     <font>
                        <Font name="Century Gothic" size="16.0" />
                     </font></Button>
               </children>
            </HBox>
            <Label fx:id="feedbackLabel" />
         </children>
      </VBox>
      <Button layoutX="458.0" layoutY="14.0" mnemonicParsing="false" onAction="#exit" prefHeight="38.0" prefWidth="44.0" style="-fx-background-color: #fff8e0; -fx-background-radius: 100px;" text="Exit" />
   </children>
   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>
</AnchorPane>
